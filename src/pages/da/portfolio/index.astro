---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';

const projects = (await getCollection('projects', ({ data }) =>
  !data.draft && data.locale === 'da'
)).sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
---

<Base
  title="Portfolio — Arthur Aizikovich, Fotograf i København"
  description="Se udvalgte projekter inden for konferencefotografi, bryllupsfotografi og eventfotografi af Arthur Aizikovich i København."
  locale="da"
>
  <article>
    <header class="page-header container">
      <p class="eyebrow">Udvalgte projekter</p>
      <h1>Portfolio</h1>
      <p class="lead">
        Konference­fotografi, bryllupper og events — dokumenteret med øje for lys og det ægte udtryk.
      </p>
    </header>

    <section class="projects container">
      {projects.length === 0 ? (
        <p class="empty">
          Projekter tilføjes snart. <a href="/da/kontakt">Kontakt mig</a> for at se mit arbejde.
        </p>
      ) : (
        <ul class="project-grid" role="list">
          {projects.map((project) => (
            <li class="project-card">
              {project.data.coverImage && (
                <a href={`/portfolio/${project.id}`} class="project-thumb" tabindex="-1" aria-hidden="true">
                  <img
                    src={project.data.coverImage}
                    alt=""
                    width="800"
                    height="533"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              )}
              <div class="project-meta">
                <h2>
                  <a href={`/portfolio/${project.id}`}>{project.data.title}</a>
                </h2>
                {project.data.description && (
                  <p>{project.data.description}</p>
                )}
                {project.data.tags && project.data.tags.length > 0 && (
                  <ul class="tag-list" role="list">
                    {project.data.tags.map((tag) => (
                      <li class="tag">#{tag}</li>
                    ))}
                  </ul>
                )}
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
  </article>
</Base>

<style>
  .page-header {
    padding-block: 0 var(--space-12);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-block-end: var(--space-4);
  }

  .lead {
    margin-block-start: var(--space-6);
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 52ch;
  }

  .projects {
    padding-block-end: var(--space-24);
    border-top: 1px solid var(--color-border);
    padding-block-start: var(--space-8);
  }

  .empty {
    color: var(--color-muted);
    padding-block: var(--space-8);
  }

  .empty a {
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .empty a:hover {
    color: var(--color-accent);
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 640px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .project-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .project-thumb {
    display: block;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--color-surface);
  }

  .project-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .project-thumb:hover img {
    transform: scale(1.03);
  }

  .project-meta h2 {
    font-size: 1rem;
    font-weight: 400;
    margin-block-end: var(--space-2);
  }

  .project-meta h2 a {
    text-decoration: none;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .project-meta h2 a:hover {
    color: var(--color-accent);
  }

  .project-meta p {
    font-size: 0.875rem;
    color: var(--color-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-block-start: var(--space-3);
    list-style: none;
    padding: 0;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.03em;
  }
</style>
