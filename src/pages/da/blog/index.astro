---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) =>
  !data.draft && data.locale === 'da'
)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base
  title="Fotografi-tips & guides — Arthur Aizikovich"
  description="Guides og råd om konferencefotografering, bryllupsfotografering og eventfotografering i København — fra fotografen bag AA Media."
  locale="da"
>
  <article>
    <header class="page-header container">
      <p class="eyebrow">Artikler</p>
      <h1>Guides & tips</h1>
      <p class="lead">
        Råd om konference-, bryllups- og eventfotografering i København.
      </p>
    </header>

    <section class="posts container">
      <ul class="post-list" role="list">
        {posts.map((post) => (
          <li class="post-item">
            <time class="post-date" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('da-DK', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <h2 class="post-title">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h2>
            <p class="post-desc">{post.data.description}</p>
            <a href={`/blog/${post.id}`} class="post-link" aria-hidden="true">
              Læs artikel →
            </a>
          </li>
        ))}
      </ul>
    </section>
  </article>
</Base>

<style>
  .page-header {
    padding-block: var(--space-16) var(--space-12);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-block-end: var(--space-4);
  }

  .lead {
    margin-block-start: var(--space-6);
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 52ch;
  }

  .posts {
    padding-block-end: var(--space-24);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: var(--content-width);
  }

  .post-item {
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: var(--space-2);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.3;
    margin-block: var(--space-2);
  }

  .post-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .post-title a:hover {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    max-width: 58ch;
  }

  .post-link {
    display: inline-block;
    margin-block-start: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: opacity var(--transition-fast);
  }

  .post-link:hover {
    opacity: 0.7;
  }
</style>
