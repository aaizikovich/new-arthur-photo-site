---
import Base from '@/layouts/Base.astro';
import FAQSchema from '@/components/seo/FAQSchema.astro';

const faqItems = [
  {
    question: 'Hvad er inkluderet i prisen?',
    answer: 'Alle pakker inkluderer forberedelse, fotografering på dagen, billedudvælgelse og professionel retuschering. Billeder leveres som højopløselige filer via et privat online-galleri.',
  },
  {
    question: 'Hvor hurtigt modtager jeg billederne?',
    answer: 'Typisk inden for 5–7 hverdage efter arrangementet. Ved store konferencer eller særlige ønsker aftaler vi leveringstid på forhånd.',
  },
  {
    question: 'Hvad sker der, hvis arrangementet løber over tid?',
    answer: 'Ekstra timer faktureres efter aftale. Jeg informerer dig altid i god tid, så der ikke er overraskelser.',
  },
  {
    question: 'Rejser du til opgaver uden for København?',
    answer: 'Ja — jeg tager opgaver over hele Danmark og internationalt. Rejseomkostninger aftales separat.',
  },
  {
    question: 'Kan jeg bestille en pakke tilpasset mine behov?',
    answer: 'Absolut. Skriv til mig med dine ønsker, og jeg sender et skræddersyet tilbud inden 24 timer.',
  },
];
---

<Base
  title="Priser — Arthur Aizikovich Fotograf København"
  description="Priser for konference-, bryllups- og eventfotografi i København. Pakker fra DKK 5.500. Kontakt for skræddersyet tilbud."
  locale="da"
>
  <FAQSchema slot="head" items={faqItems} />

  <article>
    <header class="page-header container">
      <p class="eyebrow">Priser</p>
      <h1>Gennemsigtige priser</h1>
      <p class="lead">
        Faste pakkepriser — ingen skjulte gebyrer. Kontakt for skræddersyet tilbud.
      </p>
    </header>

    <section class="pricing container">
      <ul class="rate-list" role="list">
        <li class="rate-row">
          <div class="rate-left">
            <div class="rate-header">
              <span class="rate-index">01</span>
              <h2 class="rate-name">Konference</h2>
            </div>
            <ul class="rate-features" role="list">
              <li>Op til 8 timers dækning</li>
              <li>Keynotes, panels, netværk</li>
              <li>Delegatportrætter inkl.</li>
              <li>120+ retoucherede billeder</li>
              <li>Levering: 5–7 hverdage</li>
            </ul>
          </div>
          <div class="rate-right">
            <p class="rate-price">
              <span class="price-from">fra</span>
              <strong>DKK 6.000</strong>
              <span class="price-unit">halv dag DKK 3.500</span>
            </p>
            <a href="/da/kontakt" class="rate-cta">Book konference</a>
          </div>
        </li>

        <li class="rate-row">
          <div class="rate-left">
            <div class="rate-header">
              <span class="rate-index">02</span>
              <h2 class="rate-name">Bryllup</h2>
            </div>
            <ul class="rate-features" role="list">
              <li>Forberedelse til fest</li>
              <li>Op til 10 timers dækning</li>
              <li>300+ retoucherede billeder</li>
              <li>Online-galleri i 12 mdr.</li>
              <li>Levering: 3–4 uger</li>
            </ul>
          </div>
          <div class="rate-right">
            <p class="rate-price">
              <span class="price-from">fra</span>
              <strong>DKK 12.000</strong>
              <span class="price-unit">heldagspakke</span>
            </p>
            <a href="/da/kontakt" class="rate-cta">Book bryllup</a>
          </div>
        </li>

        <li class="rate-row">
          <div class="rate-left">
            <div class="rate-header">
              <span class="rate-index">03</span>
              <h2 class="rate-name">Event</h2>
            </div>
            <ul class="rate-features" role="list">
              <li>Galaer, produktlanceringer</li>
              <li>Natteliv &amp; kulturelle events</li>
              <li>80+ retoucherede billeder</li>
              <li>Hurtig levering mulig</li>
              <li>Levering: 5–7 hverdage</li>
            </ul>
          </div>
          <div class="rate-right">
            <p class="rate-price">
              <span class="price-from">fra</span>
              <strong>DKK 5.500</strong>
              <span class="price-unit">op til 4 timer</span>
            </p>
            <a href="/da/kontakt" class="rate-cta">Book event</a>
          </div>
        </li>

        <li class="rate-row">
          <div class="rate-left">
            <div class="rate-header">
              <span class="rate-index">04</span>
              <h2 class="rate-name">Portræt &amp; headshots</h2>
            </div>
            <ul class="rate-features" role="list">
              <li>Corporate headshots</li>
              <li>Personlig branding</li>
              <li>20+ retoucherede billeder</li>
              <li>Valgfri lokation</li>
              <li>Levering: 3–5 hverdage</li>
            </ul>
          </div>
          <div class="rate-right">
            <p class="rate-price">
              <span class="price-from">fra</span>
              <strong>DKK 2.500</strong>
              <span class="price-unit">op til 1 time</span>
            </p>
            <a href="/da/kontakt" class="rate-cta">Book portræt</a>
          </div>
        </li>
      </ul>
    </section>

    <section class="faq container">
      <h2 class="section-label">Ofte stillede spørgsmål</h2>
      <dl class="faq-list">
        {faqItems.map(({ question, answer }) => (
          <div class="faq-item">
            <dt>{question}</dt>
            <dd>{answer}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="cta-strip container">
      <p class="cta-text">Har du brug for noget skræddersyet?</p>
      <a href="/da/kontakt" class="cta-btn">Få et tilbud</a>
    </section>
  </article>
</Base>

<style>
  .page-header {
    padding-block: 0 var(--space-12);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-block-end: var(--space-4);
  }

  .lead {
    margin-block-start: var(--space-6);
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 52ch;
  }

  /* Rate sheet */
  .pricing {
    padding-block-end: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .rate-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }

  .rate-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .rate-row {
      grid-template-columns: 1fr auto;
      gap: var(--space-12);
      align-items: start;
    }
  }

  .rate-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    margin-block-end: var(--space-4);
  }

  .rate-index {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .rate-name {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .rate-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-inline-start: calc(1.5rem + var(--space-4));
  }

  .rate-features li {
    font-size: 0.9rem;
    color: var(--color-muted);
    padding-inline-start: var(--space-4);
    position: relative;
  }

  .rate-features li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
  }

  .rate-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .rate-right {
      align-items: flex-end;
      min-width: 180px;
    }
  }

  .rate-price {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  @media (min-width: 640px) {
    .rate-price {
      text-align: right;
    }
  }

  .price-from {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .rate-price strong {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.5vw, 1.875rem);
    font-weight: 300;
    letter-spacing: -0.02em;
  }

  .price-unit {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .rate-cta {
    display: inline-block;
    padding: var(--space-2) var(--space-6);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    white-space: nowrap;
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .rate-cta:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  /* FAQ */
  .faq {
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-block-end: var(--space-8);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: var(--content-width);
  }

  .faq-item {
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .faq-item dt {
    font-size: 1rem;
    font-weight: 500;
    margin-block-end: var(--space-3);
  }

  .faq-item dd {
    font-size: 0.9375rem;
    color: var(--color-muted);
    max-width: 60ch;
  }

  /* CTA strip */
  .cta-strip {
    padding-block: var(--space-16);
    display: flex;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .cta-text {
    font-size: 1.25rem;
    font-family: var(--font-heading);
    font-style: italic;
  }

  .cta-btn {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    background: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: background-color var(--transition-fast);
    white-space: nowrap;
  }

  .cta-btn:hover {
    background-color: var(--color-accent);
  }
</style>
