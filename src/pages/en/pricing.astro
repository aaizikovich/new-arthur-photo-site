---
import Base from '@/layouts/Base.astro';
import FAQSchema from '@/components/seo/FAQSchema.astro';

const faqItems = [
  {
    question: 'What is included in the price?',
    answer: 'All packages include preparation, on-the-day photography, image selection and professional retouching. Images are delivered as high-resolution files via a private online gallery.',
  },
  {
    question: 'How quickly will I receive the images?',
    answer: 'Typically within 5–7 working days after the event. For large conferences or special requests, we agree on a delivery schedule in advance.',
  },
  {
    question: 'What happens if the event runs over time?',
    answer: 'Extra hours are invoiced by agreement. I will always let you know in good time so there are no surprises.',
  },
  {
    question: 'Do you travel for assignments outside Copenhagen?',
    answer: 'Yes — I take assignments across Denmark and internationally. Travel costs are agreed separately.',
  },
  {
    question: 'Can I order a package tailored to my needs?',
    answer: 'Absolutely. Send me your requirements and I will send a custom quote within 24 hours.',
  },
];
---

<Base
  title="Pricing — Arthur Aizikovich Copenhagen Photographer"
  description="Pricing for conference, wedding and event photography in Copenhagen. Packages from DKK 5,500. Get in touch for a custom quote."
  locale="en"
>
  <FAQSchema slot="head" items={faqItems} />

  <article>
    <header class="page-header container">
      <p class="eyebrow">Pricing</p>
      <h1>Transparent pricing</h1>
      <p class="lead">
        Fixed package prices — no hidden fees. Get in touch for a tailored quote.
      </p>
    </header>

    <section class="pricing container">
      <ul class="rate-list" role="list">
        <li class="rate-row">
          <div class="rate-left">
            <div class="rate-header">
              <span class="rate-index">01</span>
              <h2 class="rate-name">Conference</h2>
            </div>
            <ul class="rate-features" role="list">
              <li>Up to 8 hours coverage</li>
              <li>Keynotes, panels, networking</li>
              <li>Delegate portraits included</li>
              <li>120+ retouched images</li>
              <li>Delivery: 5–7 working days</li>
            </ul>
          </div>
          <div class="rate-right">
            <p class="rate-price">
              <span class="price-from">from</span>
              <strong>DKK 6,000</strong>
              <span class="price-unit">half day DKK 3,500</span>
            </p>
            <a href="/en/contact" class="rate-cta">Book conference</a>
          </div>
        </li>

        <li class="rate-row">
          <div class="rate-left">
            <div class="rate-header">
              <span class="rate-index">02</span>
              <h2 class="rate-name">Wedding</h2>
            </div>
            <ul class="rate-features" role="list">
              <li>Preparations to reception</li>
              <li>Up to 10 hours coverage</li>
              <li>300+ retouched images</li>
              <li>Online gallery for 12 months</li>
              <li>Delivery: 3–4 weeks</li>
            </ul>
          </div>
          <div class="rate-right">
            <p class="rate-price">
              <span class="price-from">from</span>
              <strong>DKK 12,000</strong>
              <span class="price-unit">full day package</span>
            </p>
            <a href="/en/contact" class="rate-cta">Book wedding</a>
          </div>
        </li>

        <li class="rate-row">
          <div class="rate-left">
            <div class="rate-header">
              <span class="rate-index">03</span>
              <h2 class="rate-name">Event</h2>
            </div>
            <ul class="rate-features" role="list">
              <li>Galas, product launches</li>
              <li>Nightlife &amp; cultural events</li>
              <li>80+ retouched images</li>
              <li>Rush delivery available</li>
              <li>Delivery: 5–7 working days</li>
            </ul>
          </div>
          <div class="rate-right">
            <p class="rate-price">
              <span class="price-from">from</span>
              <strong>DKK 5,500</strong>
              <span class="price-unit">up to 4 hours</span>
            </p>
            <a href="/en/contact" class="rate-cta">Book event</a>
          </div>
        </li>

        <li class="rate-row">
          <div class="rate-left">
            <div class="rate-header">
              <span class="rate-index">04</span>
              <h2 class="rate-name">Portraits &amp; headshots</h2>
            </div>
            <ul class="rate-features" role="list">
              <li>Corporate headshots</li>
              <li>Personal branding</li>
              <li>20+ retouched images</li>
              <li>Location of your choice</li>
              <li>Delivery: 3–5 working days</li>
            </ul>
          </div>
          <div class="rate-right">
            <p class="rate-price">
              <span class="price-from">from</span>
              <strong>DKK 2,500</strong>
              <span class="price-unit">up to 1 hour</span>
            </p>
            <a href="/en/contact" class="rate-cta">Book portrait</a>
          </div>
        </li>
      </ul>
    </section>

    <section class="faq container">
      <h2 class="section-label">Frequently asked questions</h2>
      <dl class="faq-list">
        {faqItems.map(({ question, answer }) => (
          <div class="faq-item">
            <dt>{question}</dt>
            <dd>{answer}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="cta-strip container">
      <p class="cta-text">Need something tailored?</p>
      <a href="/en/contact" class="cta-btn">Get a quote</a>
    </section>
  </article>
</Base>

<style>
  .page-header {
    padding-block: 0 var(--space-12);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-block-end: var(--space-4);
  }

  .lead {
    margin-block-start: var(--space-6);
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 52ch;
  }

  /* Rate sheet */
  .pricing {
    padding-block-end: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .rate-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }

  .rate-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .rate-row {
      grid-template-columns: 1fr auto;
      gap: var(--space-12);
      align-items: start;
    }
  }

  .rate-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    margin-block-end: var(--space-4);
  }

  .rate-index {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .rate-name {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .rate-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-inline-start: calc(1.5rem + var(--space-4));
  }

  .rate-features li {
    font-size: 0.9rem;
    color: var(--color-muted);
    padding-inline-start: var(--space-4);
    position: relative;
  }

  .rate-features li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
  }

  .rate-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .rate-right {
      align-items: flex-end;
      min-width: 180px;
    }
  }

  .rate-price {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  @media (min-width: 640px) {
    .rate-price {
      text-align: right;
    }
  }

  .price-from {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .rate-price strong {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.5vw, 1.875rem);
    font-weight: 300;
    letter-spacing: -0.02em;
  }

  .price-unit {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .rate-cta {
    display: inline-block;
    padding: var(--space-2) var(--space-6);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    white-space: nowrap;
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .rate-cta:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  /* FAQ */
  .faq {
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-block-end: var(--space-8);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    max-width: var(--content-width);
  }

  .faq-item {
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .faq-item dt {
    font-size: 1rem;
    font-weight: 500;
    margin-block-end: var(--space-3);
  }

  .faq-item dd {
    font-size: 0.9375rem;
    color: var(--color-muted);
    max-width: 60ch;
  }

  /* CTA strip */
  .cta-strip {
    padding-block: var(--space-16);
    display: flex;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .cta-text {
    font-size: 1.25rem;
    font-family: var(--font-heading);
    font-style: italic;
  }

  .cta-btn {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    background: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: background-color var(--transition-fast);
    white-space: nowrap;
  }

  .cta-btn:hover {
    background-color: var(--color-accent);
  }
</style>
