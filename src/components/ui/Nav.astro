---
interface Props {
  locale?: 'da' | 'en';
}

const { locale = 'da' } = Astro.props;

const isDa = locale === 'da';
const currentPath = Astro.url.pathname;
// Normalize for active-link comparison: strip trailing slash except for root "/"
const normPath = (p: string) => (p.endsWith('/') && p.length > 1 ? p.slice(0, -1) : p);

const navLinks = isDa
  ? [
      { href: '/da/', label: 'Hjem' },
      { href: '/da/portfolio', label: 'Portfolio' },
      { href: '/da/priser', label: 'Priser' },
      { href: '/da/om', label: 'Om' },
      { href: '/da/kontakt', label: 'Kontakt' },
    ]
  : [
      { href: '/en/', label: 'Home' },
      { href: '/en/portfolio', label: 'Portfolio' },
      { href: '/en/pricing', label: 'Pricing' },
      { href: '/en/about', label: 'About' },
      { href: '/en/contact', label: 'Contact' },
    ];

const daToEn: Record<string, string> = {
  '/da/':          '/en/',
  '/da/portfolio': '/en/portfolio',
  '/da/priser':    '/en/pricing',
  '/da/om':        '/en/about',
  '/da/kontakt':   '/en/contact',
  '/da/blog':      '/en/blog',
};
const enToDa: Record<string, string> = Object.fromEntries(
  Object.entries(daToEn).map(([da, en]) => [en, da])
);

function altLangUrl(path: string): string {
  const clean = path.replace(/\/$/, '') || '/';
  if (isDa) {
    if (daToEn[path]) return daToEn[path];
    if (daToEn[clean]) return daToEn[clean];
    return path.replace(/^\/da\//, '/en/');
  } else {
    if (enToDa[path]) return enToDa[path];
    if (enToDa[clean]) return enToDa[clean];
    return path.replace(/^\/en\//, '/da/');
  }
}

const altLang = isDa
  ? { href: altLangUrl(currentPath), label: 'EN' }
  : { href: altLangUrl(currentPath), label: 'DA' };
---

<header class="site-header">
  <nav class="nav container" aria-label={isDa ? 'Primær navigation' : 'Primary navigation'}>
    <a href={isDa ? '/da/' : '/en/'} class="nav-logo" aria-label="Arthur Aizikovich — forside">
      AA
    </a>

    <ul class="nav-links" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', { 'is-active': normPath(currentPath) === normPath(href) }]}
            aria-current={normPath(currentPath) === normPath(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav-actions">
      <a href={altLang.href} class="lang-switch" hreflang={isDa ? 'en' : 'da'}>
        {altLang.label}
      </a>
      <button id="theme-toggle" class="theme-toggle" aria-label={isDa ? 'Skift farvetema' : 'Toggle colour theme'} title={isDa ? 'Skift farvetema' : 'Toggle colour theme'} type="button">
        <span class="theme-toggle-icon"></span>
      </button>
      <a href={isDa ? '/da/kontakt' : '/en/contact'} class="nav-cta">
        {isDa ? 'Book møde' : 'Book a call'}
      </a>
      <button
        id="menu-toggle"
        class="menu-toggle"
        aria-label={isDa ? 'Åbn menu' : 'Open menu'}
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <ul role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['mobile-link', { 'is-active': normPath(currentPath) === normPath(href) }]}
            aria-current={normPath(currentPath) === normPath(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <div class="mobile-footer">
      <a href={altLang.href} class="lang-switch" hreflang={isDa ? 'en' : 'da'}>
        {altLang.label}
      </a>
      <a href={isDa ? '/da/kontakt' : '/en/contact'} class="nav-cta">
        {isDa ? 'Book møde' : 'Book a call'}
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in oklch, var(--color-bg) 90%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    height: 3.5rem;
  }

  .nav-logo {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: var(--color-text);
    flex-shrink: 0;
  }

  .nav-logo:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: var(--space-6);
    flex: 1;
  }

  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    font-size: 0.9375rem;
    text-decoration: none;
    color: var(--color-muted);
    transition: color var(--transition-fast);
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--color-text);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-inline-start: auto;
  }

  .lang-switch {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-decoration: none;
    color: var(--color-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color var(--transition-fast);
  }

  .lang-switch:hover {
    color: var(--color-accent);
  }

  .nav-cta {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-text);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .nav-cta:hover {
    color: var(--color-bg);
    background-color: var(--color-text);
    border-color: var(--color-text);
  }

  /* Hide desktop CTA on mobile — it's in the mobile menu */
  .nav-actions .nav-cta {
    display: none;
  }

  @media (min-width: 1024px) {
    .nav-actions .nav-cta {
      display: inline-block;
    }
  }

  /* Theme toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-muted);
    transition: color var(--transition-fast);
    padding: 0;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    color: var(--color-text);
  }

  .theme-toggle-icon {
    display: block;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    position: relative;
    transition: box-shadow var(--transition-fast);
  }

  .theme-toggle-icon::before {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 50%;
    background: currentColor;
    transition: transform var(--transition-base);
  }

  [data-theme="dark"] .theme-toggle-icon::before {
    transform: translateX(35%) scale(0.85);
  }

  /* Hamburger */
  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.75rem;
    height: 2.75rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    flex-shrink: 0;
    color: var(--color-text);
  }

  @media (min-width: 1024px) {
    .menu-toggle {
      display: none;
    }
  }

  .menu-bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: currentColor;
    transform-origin: center;
    transition:
      transform var(--transition-base),
      opacity var(--transition-fast);
  }

  /* Open state — X */
  .menu-toggle[aria-expanded="true"] .menu-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-toggle[aria-expanded="true"] .menu-bar:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle[aria-expanded="true"] .menu-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile menu panel */
  .mobile-menu {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--transition-base);
    overflow: hidden;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-menu[aria-hidden="false"] {
    grid-template-rows: 1fr;
  }

  /* Wrap both children so grid-template-rows collapse works */
  .mobile-menu > ul,
  .mobile-menu > .mobile-footer {
    min-height: 0;
  }

  .mobile-menu > ul {
    padding: var(--space-6) var(--gutter) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mobile-link {
    display: block;
    padding-block: var(--space-4);
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 5vw, 2rem);
    font-weight: 300;
    text-decoration: none;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast);
    letter-spacing: -0.02em;
  }

  .mobile-link:first-child {
    border-top: 1px solid var(--color-border);
  }

  .mobile-link:hover,
  .mobile-link.is-active {
    color: var(--color-text);
  }

  .mobile-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--gutter) var(--space-6);
  }

  .mobile-footer .lang-switch {
    font-size: 0.8125rem;
  }

  .mobile-footer .nav-cta {
    display: inline-block;
  }

  @media (min-width: 1024px) {
    .mobile-menu {
      display: none;
    }
  }
</style>

<script>
  // Theme toggle
  const themeBtn = document.getElementById('theme-toggle');
  const html = document.documentElement;

  themeBtn?.addEventListener('click', () => {
    const isDark = html.getAttribute('data-theme') === 'dark';
    html.setAttribute('data-theme', isDark ? 'light' : 'dark');
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  });

  // Mobile menu
  const menuToggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu');

  function openMenu() {
    menuToggle?.setAttribute('aria-expanded', 'true');
    menuToggle?.setAttribute('aria-label', menuToggle.closest('[lang]')?.getAttribute('lang') === 'da' ? 'Luk menu' : 'Close menu');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menuToggle?.setAttribute('aria-expanded', 'false');
    menuToggle?.setAttribute('aria-label', menuToggle.closest('[lang]')?.getAttribute('lang') === 'da' ? 'Åbn menu' : 'Open menu');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', () => {
    const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuToggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
      menuToggle.focus();
    }
  });

  // Close when a link is clicked
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
