---
interface Props {
  locale?: 'da' | 'en';
}

const { locale = 'da' } = Astro.props;

const t = locale === 'da'
  ? {
      dialog:  'Billedvisning',
      close:   'Luk billedvisning',
      prev:    'Forrige billede',
      next:    'Næste billede',
    }
  : {
      dialog:  'Image viewer',
      close:   'Close image viewer',
      prev:    'Previous image',
      next:    'Next image',
    };
---

<div
  class="lightbox"
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label={t.dialog}
  aria-hidden="true"
  inert
>
  <button class="lightbox-close" id="lightbox-close" aria-label={t.close} type="button">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label={t.prev} type="button">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="m15 18-6-6 6-6"/>
    </svg>
  </button>

  <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label={t.next} type="button">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="m9 18 6-6-6-6"/>
    </svg>
  </button>

  <figure class="lightbox-figure">
    <img
      id="lightbox-img"
      src=""
      alt=""
      decoding="async"
      class="lightbox-image"
    />
    <figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
  </figure>
</div>

<script>
  // client:visible equivalent — only initialise when gallery enters viewport
  const gallery = document.querySelector<HTMLElement>('[data-gallery]');
  if (!gallery) throw new Error('Lightbox: no [data-gallery] found');

  let isInitialised = false;

  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting && !isInitialised) {
        initLightbox();
        isInitialised = true;
        observer.disconnect();
      }
    },
    { threshold: 0.05 }
  );

  observer.observe(gallery);

  // ─── State ───────────────────────────────────────────────────────────────────

  let currentIndex = 0;
  let images: { src: string; alt: string }[] = [];

  // ─── Init ────────────────────────────────────────────────────────────────────

  function initLightbox() {
    const triggers = gallery!.querySelectorAll<HTMLButtonElement>('[data-lightbox-trigger]');
    images = Array.from(triggers).map((t) => ({
      src: t.dataset.src ?? '',
      alt: t.dataset.alt ?? '',
    }));

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        openLightbox(Number(trigger.dataset.index ?? 0));
      });
    });

    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
    document.getElementById('lightbox-prev')?.addEventListener('click', () => navigate(-1));
    document.getElementById('lightbox-next')?.addEventListener('click', () => navigate(1));

    document.getElementById('lightbox')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'lightbox') closeLightbox();
    });

    document.addEventListener('keydown', handleKey);
  }

  // ─── Open / Close ────────────────────────────────────────────────────────────

  function openLightbox(index: number) {
    currentIndex = index;
    render();

    const lb = document.getElementById('lightbox')!;
    lb.setAttribute('aria-hidden', 'false');
    lb.removeAttribute('inert');
    lb.classList.add('is-open');

    document.body.style.overflow = 'hidden';
    document.getElementById('lightbox-close')?.focus();
  }

  function closeLightbox() {
    const lb = document.getElementById('lightbox')!;
    lb.setAttribute('aria-hidden', 'true');
    lb.setAttribute('inert', '');
    lb.classList.remove('is-open');
    document.body.style.overflow = '';

    const trigger = gallery!.querySelector<HTMLButtonElement>(`[data-index="${currentIndex}"]`);
    trigger?.focus();
  }

  // ─── Navigation ──────────────────────────────────────────────────────────────

  function navigate(dir: 1 | -1) {
    currentIndex = (currentIndex + dir + images.length) % images.length;
    render();
  }

  function render() {
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const caption = document.getElementById('lightbox-caption')!;
    const { src, alt } = images[currentIndex];

    img.classList.add('is-loading');
    img.onload = () => img.classList.remove('is-loading');
    img.src = src;
    img.alt = alt;
    caption.textContent = alt;

    const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement;
    const single = images.length === 1;
    prevBtn.hidden = single;
    nextBtn.hidden = single;
  }

  // ─── Keyboard + Focus Trap ───────────────────────────────────────────────────

  function handleKey(e: KeyboardEvent) {
    const lb = document.getElementById('lightbox');
    if (!lb?.classList.contains('is-open')) return;

    if (e.key === 'Escape') { closeLightbox(); return; }
    if (e.key === 'ArrowLeft') { navigate(-1); return; }
    if (e.key === 'ArrowRight') { navigate(1); return; }

    // Focus trap — cycle within visible lightbox buttons
    if (e.key === 'Tab') {
      const focusable = Array.from(
        lb.querySelectorAll<HTMLElement>('button:not([hidden])')
      );
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  }
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 900;
    display: grid;
    place-items: center;
    /* Fixed dark overlay — does not use --color-text so it stays dark in both themes */
    background: rgb(10 10 10 / 0.92);
    padding: var(--space-8) var(--gutter);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: all;
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox { transition: none; }
  }

  .lightbox-figure {
    position: relative;
    max-width: min(90vw, 1200px);
    max-height: 90vh;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .lightbox-image {
    display: block;
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    transition: opacity var(--transition-fast);
  }

  .lightbox-image.is-loading {
    opacity: 0.3;
  }

  .lightbox-caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgb(240 236 230 / 0.6);
    letter-spacing: 0.05em;
    text-align: center;
    max-width: 60ch;
  }

  /* Close button — 44×44px touch target */
  .lightbox-close {
    position: fixed;
    top: var(--space-6);
    right: var(--space-6);
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid rgb(240 236 230 / 0.25);
    border-radius: 50%;
    background: transparent;
    color: rgb(240 236 230 / 0.85);
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .lightbox-close:hover,
  .lightbox-close:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
    outline: none;
  }

  /* Prev / Next */
  .lightbox-nav {
    position: fixed;
    top: 50%;
    translate: 0 -50%;
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid rgb(240 236 230 / 0.2);
    background: transparent;
    color: rgb(240 236 230 / 0.85);
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .lightbox-prev { left: var(--space-4); }
  .lightbox-next { right: var(--space-4); }

  @media (min-width: 1024px) {
    .lightbox-prev { left: var(--space-8); }
    .lightbox-next { right: var(--space-8); }
  }

  .lightbox-nav:hover,
  .lightbox-nav:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
    outline: none;
  }
</style>
