---
import Base from '@/layouts/Base.astro';
import ContactForm from '@/components/ui/ContactForm.astro';
---

<Base
  title="Kontakt — Arthur Aizikovich Fotograf København"
  description="Book Arthur Aizikovich til dit næste arrangement. Konferencer, bryllupper og events i København og hele Danmark."
  locale="da"
>
  <article>
    <header class="page-header container">
      <p class="eyebrow">Kontakt</p>
      <h1>Lad os tale om dit projekt</h1>
      <p class="lead">
        Udfyld formularen nedenfor, send en e-mail eller find mig på LinkedIn.
        Jeg svarer typisk inden for 24 timer.
      </p>
    </header>

    <section class="contact-layout container">
      <div class="form-col">
        <ContactForm locale="da" />
      </div>

      <aside class="info-col">
        <dl class="contact-details">
          <div class="detail">
            <dt>E-mail</dt>
            <dd>
              <a href="mailto:arthur@aamedia.dk">arthur@aamedia.dk</a>
            </dd>
          </div>
          <div class="detail">
            <dt>Instagram</dt>
            <dd>
              <a
                href="https://www.instagram.com/arthuraizikovich"
                target="_blank"
                rel="noopener noreferrer"
              >
                @arthuraizikovich
              </a>
            </dd>
          </div>
          <div class="detail">
            <dt>LinkedIn</dt>
            <dd>
              <a
                href="https://www.linkedin.com/in/arthuraizikovich"
                target="_blank"
                rel="noopener noreferrer"
              >
                arthuraizikovich
              </a>
            </dd>
          </div>
          <div class="detail">
            <dt>Beliggenhed</dt>
            <dd>København, Danmark</dd>
          </div>
          <div class="detail">
            <dt>Svartid</dt>
            <dd>Inden for 24 timer</dd>
          </div>
        </dl>
      </aside>
    </section>
  </article>
</Base>

<style>
  .page-header {
    padding-block: 0 var(--space-12);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-block-end: var(--space-4);
  }

  .lead {
    margin-block-start: var(--space-6);
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 52ch;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    padding-block-end: var(--space-24);
  }

  @media (min-width: 1024px) {
    .contact-layout {
      grid-template-columns: 3fr 2fr;
    }
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-block-start: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 1024px) {
    .contact-details {
      border-top: none;
      border-left: 1px solid var(--color-border);
      padding-block-start: 0;
      padding-inline-start: var(--space-8);
    }
  }

  .detail dt {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-block-end: var(--space-1);
  }

  .detail dd {
    font-size: 0.9375rem;
  }

  .detail dd a {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .detail dd a:hover {
    color: var(--color-accent);
  }
</style>
