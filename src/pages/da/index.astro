---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import LocalBusinessSchema from '@/components/seo/LocalBusinessSchema.astro';

const projects = (await getCollection('projects', ({ data }) =>
  !data.draft && data.locale === 'da'
)).sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
---

<Base
  title="Arthur Aizikovich — Fotograf i København"
  description="Professionel fotograf i København med speciale i konferencer, bryllupper, events og portrætter. Kontakt for pris og ledige datoer."
  locale="da"
>
  <LocalBusinessSchema slot="head" />

  <section class="hero container">
    <p class="hero-eyebrow">Fotograf i København</p>
    <h1>Øjeblikke, der&nbsp;fortæller historier</h1>
    <p class="hero-body">
      Konference­fotografi, bryllups­billeder og event­dokumentation — leveret med øje for lys, timing og det ægte udtryk.
    </p>
    <a href="/kontakt" class="hero-cta">Book en samtale</a>
  </section>

  {projects.length > 0 && (
    <section class="recent container">
      <h2 class="section-label">Seneste arbejde</h2>
      <ul class="project-grid" role="list">
        {projects.map((project) => (
          <li class="project-card">
            {project.data.coverImage && (
              <a href={`/portfolio/${project.id}`} class="project-thumb" tabindex="-1" aria-hidden="true">
                <img
                  src={project.data.coverImage}
                  alt=""
                  width="800"
                  height="533"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}
            <div class="project-meta">
              <h3>
                <a href={`/portfolio/${project.id}`}>{project.data.title}</a>
              </h3>
              {project.data.description && (
                <p>{project.data.description}</p>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  .hero {
    padding-block: var(--space-24) var(--space-16);
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-block-end: var(--space-4);
  }

  .hero h1 {
    margin-block-end: var(--space-6);
  }

  .hero-body {
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 52ch;
    margin-block-end: var(--space-8);
  }

  .hero-cta {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-bg);
    background-color: var(--color-text);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .hero-cta:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  /* Recent work */
  .recent {
    padding-block: var(--space-16);
    border-top: 1px solid var(--color-border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-block-end: var(--space-8);
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 640px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .project-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .project-thumb {
    display: block;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--color-surface);
  }

  .project-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .project-thumb:hover img {
    transform: scale(1.03);
  }

  .project-meta h3 {
    font-size: 1rem;
    font-weight: 400;
    margin-block-end: var(--space-2);
  }

  .project-meta h3 a {
    text-decoration: none;
    color: var(--color-text);
  }

  .project-meta h3 a:hover {
    color: var(--color-accent);
  }

  .project-meta p {
    font-size: 0.875rem;
    color: var(--color-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
