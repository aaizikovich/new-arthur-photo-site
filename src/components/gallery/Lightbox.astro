---
/**
 * Lightbox — click-to-enlarge overlay for Gallery.astro.
 *
 * Astro .astro components cannot use client: directives on themselves —
 * that's reserved for UI-framework components. The equivalent of
 * `client:visible` is achieved here with IntersectionObserver: the JS
 * is only initialised once the gallery enters the viewport.
 */
---

<!-- Lightbox overlay (hidden until triggered) -->
<div
  class="lightbox"
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Billedvisning"
  aria-hidden="true"
>
  <button class="lightbox-close" id="lightbox-close" aria-label="Luk billedvisning" type="button">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Forrige billede" type="button">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="m15 18-6-6 6-6"/>
    </svg>
  </button>

  <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Næste billede" type="button">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="m9 18 6-6-6-6"/>
    </svg>
  </button>

  <figure class="lightbox-figure">
    <img
      id="lightbox-img"
      src=""
      alt=""
      decoding="async"
      class="lightbox-image"
    />
    <figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
  </figure>
</div>

<script>
  // client:visible equivalent — only initialise when gallery enters viewport
  const gallery = document.querySelector<HTMLElement>('[data-gallery]');
  if (!gallery) throw new Error('Lightbox: no [data-gallery] found');

  let isInitialised = false;

  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting && !isInitialised) {
        initLightbox();
        isInitialised = true;
        observer.disconnect();
      }
    },
    { threshold: 0.05 }
  );

  observer.observe(gallery);

  // ─── State ───────────────────────────────────────────────────────────────────

  let currentIndex = 0;
  let images: { src: string; alt: string }[] = [];

  // ─── Init ────────────────────────────────────────────────────────────────────

  function initLightbox() {
    // Collect all trigger data once
    const triggers = gallery!.querySelectorAll<HTMLButtonElement>('[data-lightbox-trigger]');
    images = Array.from(triggers).map((t) => ({
      src: t.dataset.src ?? '',
      alt: t.dataset.alt ?? '',
    }));

    // Open on click
    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const idx = Number(trigger.dataset.index ?? 0);
        openLightbox(idx);
      });
    });

    // Controls
    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
    document.getElementById('lightbox-prev')?.addEventListener('click', () => navigate(-1));
    document.getElementById('lightbox-next')?.addEventListener('click', () => navigate(1));

    // Click backdrop to close
    document.getElementById('lightbox')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'lightbox') closeLightbox();
    });

    // Keyboard
    document.addEventListener('keydown', handleKey);
  }

  // ─── Open / Close ────────────────────────────────────────────────────────────

  function openLightbox(index: number) {
    currentIndex = index;
    render();

    const lb = document.getElementById('lightbox')!;
    lb.setAttribute('aria-hidden', 'false');
    lb.classList.add('is-open');

    // Trap focus — return focus on close
    document.body.style.overflow = 'hidden';
    document.getElementById('lightbox-close')?.focus();
  }

  function closeLightbox() {
    const lb = document.getElementById('lightbox')!;
    lb.setAttribute('aria-hidden', 'true');
    lb.classList.remove('is-open');
    document.body.style.overflow = '';

    // Return focus to the trigger that opened it
    const trigger = gallery!.querySelector<HTMLButtonElement>(
      `[data-index="${currentIndex}"]`
    );
    trigger?.focus();
  }

  // ─── Navigation ──────────────────────────────────────────────────────────────

  function navigate(dir: 1 | -1) {
    currentIndex = (currentIndex + dir + images.length) % images.length;
    render();
  }

  function render() {
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const caption = document.getElementById('lightbox-caption')!;
    const { src, alt } = images[currentIndex];

    img.classList.add('is-loading');
    img.onload = () => img.classList.remove('is-loading');
    img.src = src;
    img.alt = alt;
    caption.textContent = alt;

    // Hide prev/next when only one image
    const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement;
    const single = images.length === 1;
    prevBtn.hidden = single;
    nextBtn.hidden = single;
  }

  // ─── Keyboard ────────────────────────────────────────────────────────────────

  function handleKey(e: KeyboardEvent) {
    const lb = document.getElementById('lightbox');
    if (!lb?.classList.contains('is-open')) return;

    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  }
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 900;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--color-text) 90%, transparent);
    padding: var(--space-8) var(--gutter);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* Motion preference */
  @media (prefers-reduced-motion: reduce) {
    .lightbox { transition: none; }
  }

  .lightbox-figure {
    position: relative;
    max-width: min(90vw, 1200px);
    max-height: 90vh;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .lightbox-image {
    display: block;
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    transition: opacity var(--transition-fast);
  }

  .lightbox-image.is-loading {
    opacity: 0.3;
  }

  .lightbox-caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-bg) 70%, transparent);
    letter-spacing: 0.05em;
    text-align: center;
    max-width: 60ch;
  }

  /* Close button */
  .lightbox-close {
    position: fixed;
    top: var(--space-6);
    right: var(--space-6);
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid color-mix(in srgb, var(--color-bg) 30%, transparent);
    border-radius: 50%;
    background: transparent;
    color: var(--color-bg);
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .lightbox-close:hover,
  .lightbox-close:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
    outline: none;
  }

  /* Prev / Next */
  .lightbox-nav {
    position: fixed;
    top: 50%;
    translate: 0 -50%;
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid color-mix(in srgb, var(--color-bg) 25%, transparent);
    background: transparent;
    color: var(--color-bg);
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .lightbox-prev { left: var(--space-4); }
  .lightbox-next { right: var(--space-4); }

  @media (min-width: 1024px) {
    .lightbox-prev { left: var(--space-8); }
    .lightbox-next { right: var(--space-8); }
  }

  .lightbox-nav:hover,
  .lightbox-nav:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
    outline: none;
  }
</style>
