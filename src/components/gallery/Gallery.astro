---
/**
 * Gallery — responsive photo grid for project pages.
 * Pairs with Lightbox.astro (included below) for click-to-enlarge.
 */

export interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  images: GalleryImage[];
}

const { images = [] } = Astro.props;
---

{images.length > 0 && (
  <section class="gallery" data-gallery aria-label="Billedgalleri">
    {images.map((image, i) => (
      <button
        class="gallery-item"
        data-lightbox-trigger
        data-index={i}
        data-src={image.src}
        data-alt={image.alt}
        aria-label={`Vis billede: ${image.alt}`}
        type="button"
      >
        <img
          src={image.src}
          alt={image.alt}
          width="800"
          height="600"
          loading={i < 4 ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={i === 0 ? 'high' : 'auto'}
          class="gallery-img"
        />
        <span class="gallery-overlay" aria-hidden="true" />
      </button>
    ))}
  </section>
)}

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
    padding-block: var(--space-8);
  }

  @media (min-width: 640px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
    }
  }

  @media (min-width: 1024px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-4);
    }
  }

  /* Every 7th item spans 2 columns for visual rhythm */
  @media (min-width: 640px) {
    .gallery-item:nth-child(7n + 1) {
      grid-column: span 2;
    }
  }

  .gallery-item {
    position: relative;
    display: block;
    padding: 0;
    border: none;
    background: var(--color-surface);
    cursor: pointer;
    overflow: hidden;
    aspect-ratio: 3 / 2;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-base);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-text) 0%, transparent);
    transition: background var(--transition-fast);
  }

  .gallery-item:hover .gallery-img,
  .gallery-item:focus-visible .gallery-img {
    transform: scale(1.03);
  }

  .gallery-item:hover .gallery-overlay,
  .gallery-item:focus-visible .gallery-overlay {
    background: color-mix(in srgb, var(--color-text) 20%, transparent);
  }

  .gallery-item:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
